    "ParkingManager.getAvailableSpots(VehicleType type): int",
    "ParkingSpotAllocator.allocateSpot(VehicleType type): Optional<ParkingSpot>",
    "ParkingSpotAllocator.releaseSpot(int spotId): void",
    "FeeCalculator.calculateFee(Vehicle vehicle, LocalDateTime exitTime): double",
    "VehicleType enum: MOTORCYCLE(1.0), CAR(2.0), BUS(4.0)",
    "ParkingSpot record: spotId, floor, supportedType, isOccupied, size",
    "Vehicle record: licensePlate, type, entryTime, assignedSpot",
    "ParkingTransaction record: transactionId, vehicle, entryTime, exitTime, fee"
