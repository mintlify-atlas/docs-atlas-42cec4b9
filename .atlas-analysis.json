  "keyFeatures": [
    "Automatic spot allocation based on vehicle type and size",
    "Multi-floor parking lot support",
    "Thread-safe concurrent operations using ReadWriteLock and ConcurrentHashMap",
    "Asynchronous check-in and check-out with CompletableFuture",
    "Duration-based fee calculation with per-vehicle-type hourly rates",
    "Immutable data model using Java records",
    "Real-time availability tracking"
  ],
  "publicApiSurface": [
    "ParkingManager(int floors, int spotsPerFloor)",
    "ParkingManager.checkIn(String licensePlate, VehicleType type): CompletableFuture<Vehicle>",
